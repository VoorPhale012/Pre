hitboxConnection = RunService.Heartbeat:Connect(function()
    if isReboundingPaused or entityFinished or not rootPart or not rootPart.Parent then return end
    
    local character = Player.Character
    local humanoidRootPart = character and character:FindFirstChild("HumanoidRootPart")
    
    if humanoidRootPart then
        local direction = humanoidRootPart.Position - rootPart.Position
        local distance = direction.Magnitude
        
        if distance <= EntityConfig.HitboxRadius then
            -- Kiểm tra tủ an toàn
            local isSafeInLocker = false
            local roomsFolder = Gameplay:FindFirstChild("Rooms")
            if roomsFolder then
                for _, descendant in ipairs(roomsFolder:GetDescendants()) do
                    if descendant:IsA("Model") and descendant.Name == "Locker" then
                        local playerInValue = descendant:FindFirstChild("PlayerIn", true)
                        if playerInValue and playerInValue.Value == true then
                            isSafeInLocker = true
                            break
                        end
                    end
                end
            end
            
            if isSafeInLocker then return end
            
            -- Raycast check
            local params = RaycastParams.new()
            params.FilterType = Enum.RaycastFilterType.Exclude
            params.FilterDescendantsInstances = {entityModel, character}
            params.IgnoreWater = true
            
            local raycastResult = Workspace:Raycast(rootPart.Position, direction, params)
            
            if not raycastResult then
                -- LOGIC MỚI: Xử lý Hút máu liên tục hoặc Tóm đơn lẻ
                if EntityConfig.ConstantBloodSucking then
                    if not isSuckingBlood then
                        isSuckingBlood = true
                        task.spawn(function()
                            -- Tiếp tục hút máu khi còn trong phạm vi hitbox
                            while (Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") and 
                                  (Player.Character.HumanoidRootPart.Position - rootPart.Position).Magnitude <= EntityConfig.HitboxRadius) do
                                
                                executeJumpscare()
                                task.wait(EntityConfig.DelayEachDamage)
                            end
                            isSuckingBlood = false
                        end)
                    end
                else
                    -- Logic cũ: Chỉ tóm 1 lần
                    executeJumpscare()
                end
            end
        end
    end
end)

