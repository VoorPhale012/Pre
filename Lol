function loadSound(p25)
    local v26 = Instance.new("Sound")
    local v27 = tostring(p25[1])
    local v28 = p25[2]
    local v29 = next
    local v30 = nil
    while true do
        local v31
        v30, v31 = v29(v28, v30)
        if v30 == nil then
            break
        end
        if v30 ~= "SoundId" and v30 ~= "Parent" then
            v26[v30] = v31
        end
    end
    if v27:find("rbxasset://") then
        v26.SoundId = v27
    else
        v26.SoundId = "rbxassetid://" .. v27:gsub("%D", "")
    end
    v26.Parent = workspace
    return v26
end

